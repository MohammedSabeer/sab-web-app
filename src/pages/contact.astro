---
import BaseLayout from '../layouts/BaseLayout.astro';

const seoData = {
  title: 'Contact Us - SABI TECH',
  description: 'Get in touch with SABI TECH. Reach us for software development inquiries, support, or partnership opportunities. Email: info@techlogicvibe.com | Phone: +91 7200650707',
};
---

<BaseLayout {...seoData}>
  <!-- Hero -->
  <section class="bg-linear-to-br from-slate-900 via-blue-950 to-slate-900 text-white py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center px-4 py-2 mb-6 bg-blue-600/20 border border-blue-500/30 text-blue-300 text-sm font-semibold rounded-full">
        Get In Touch
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        Contact <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">SABI TECH</span>
      </h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto leading-relaxed">
        Have a question, a project in mind, or need support? We'd love to hear from you. Reach out and we'll get back to you promptly.
      </p>
    </div>
  </section>

  <!-- Contact Cards + Form -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Contact Info Cards -->
        <div class="space-y-6">

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-800 mb-1">Email Us</h3>
            <p class="text-sm text-slate-500 mb-2">We reply within 24 hours</p>
            <a href="mailto:info@techlogicvibe.com" class="text-blue-600 hover:underline text-sm font-medium">info@techlogicvibe.com</a>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-800 mb-1">Call Us</h3>
            <p class="text-sm text-slate-500 mb-2">Mon – Fri, 9:00 – 18:00 IST</p>
            <a href="tel:+917200650707" class="text-teal-600 hover:underline text-sm font-medium">+91 7200650707</a>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-800 mb-1">Our Address</h3>
            <p class="text-sm text-slate-500 mb-2">SABI TECH</p>
            <p class="text-sm text-slate-600 leading-relaxed">Rose Avenue, Coimbatore,<br>Tamil Nadu, India</p>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-800 mb-1">Business Hours</h3>
            <p class="text-sm text-slate-600">Monday – Friday<br>9:00 AM – 6:00 PM IST</p>
          </div>

        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
            <h2 class="text-2xl font-bold text-slate-900 mb-2">Send Us a Message</h2>
            <p class="text-slate-500 text-sm mb-8">Fill out the form below and our team will get back to you as soon as possible.</p>

            <form
              name="contact"
              method="POST"
              action="/rfq"
              class="space-y-6"
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="firstName" class="block text-sm font-medium text-slate-700 mb-1">First Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    required
                    placeholder="John"
                    class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none text-sm transition-all"
                  />
                </div>
                <div>
                  <label for="lastName" class="block text-sm font-medium text-slate-700 mb-1">Last Name <span class="text-red-500">*</span></label>
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    required
                    placeholder="Doe"
                    class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none text-sm transition-all"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email Address <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="john@example.com"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none text-sm transition-all"
                />
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="+91 98765 43210"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none text-sm transition-all"
                />
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-slate-700 mb-1">Subject <span class="text-red-500">*</span></label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none text-sm transition-all bg-white"
                >
                  <option value="" disabled selected>Select a subject</option>
                  <option value="project-inquiry">Project Inquiry</option>
                  <option value="general-support">General Support</option>
                  <option value="billing">Billing & Payments</option>
                  <option value="refund">Refund Request</option>
                  <option value="partnership">Partnership</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-1">Message <span class="text-red-500">*</span></label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Tell us about your inquiry or project..."
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-100 outline-none text-sm transition-all resize-none"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-sm font-semibold text-white bg-linear-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 rounded-lg shadow-md hover:shadow-lg transition-all"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                Send Message
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-12 bg-white border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-slate-500 text-sm mb-4">Looking for something specific?</p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/rfq" class="inline-flex items-center px-5 py-2 text-sm font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-full transition-colors">Request a Quote</a>
        <a href="/documentation" class="inline-flex items-center px-5 py-2 text-sm font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-full transition-colors">Documentation</a>
        <a href="/refund_policy" class="inline-flex items-center px-5 py-2 text-sm font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-full transition-colors">Refund Policy</a>
        <a href="/privacy_policy" class="inline-flex items-center px-5 py-2 text-sm font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-full transition-colors">Privacy Policy</a>
      </div>
    </div>
  </section>
</BaseLayout>
