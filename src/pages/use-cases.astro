---
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Button from '@components/ui/Button.astro';
import TestimonialCard from '@components/ui/TestimonialCard.astro';
import UseCaseTabs from '@components/react/UseCaseTabs';
import StatsCards from '@components/react/StatsCards';
import { Image } from 'astro:assets';

import ecommerceImg from '@assets/photo-1607082349566-187342175e2f.jpg';
import healthcareImg from '@assets/photo-1587854692152-cbe660dbde88.jpg';
import automotiveImg from '@assets/photo-1581091226825-a6a2a5aee158.jpg';
import technologyImg from '@assets/photo-1518770660439-4636190af475.jpg';
import consumerGoodsImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import foodBeverageImg from '@assets/photo-1542838132-92c53300491e.jpg';

import testimonial1Img from '@assets/photo-1494790108377-be9c29b29330.jpg';
import testimonial2Img from '@assets/photo-1559839734-2b71ea197ec2.jpg';
import testimonial3Img from '@assets/photo-1507003211169-0a1dd7228f2d.jpg';

import heroBgImg from '@assets/photo-1551288049-bebda4e38f71.jpg';
import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';

const useCases:any[] = [
  {
    industry: 'E-Commerce & Retail',
    iconName: 'ShoppingCart',
    image: ecommerceImg,
    challenge: 'Building a scalable online marketplace with real-time inventory management, secure payments, and personalized shopping experiences.',
    solution: 'Full-stack e-commerce platform with React frontend, Node.js backend, integrated payment gateways, AI-powered recommendations, and mobile apps.',
    results: [
      '300% increase in online sales',
      '50% reduction in cart abandonment',
      'Real-time inventory across channels',
      '95% customer satisfaction score'
    ]
  },
  {
    industry: 'Healthcare & Telemedicine',
    iconName: 'Heart',
    image: healthcareImg,
    challenge: 'Creating HIPAA-compliant telemedicine platform with video consultations, electronic health records, and appointment scheduling.',
    solution: 'Secure healthcare platform with end-to-end encryption, video conferencing API integration, patient portal, and doctor dashboard.',
    results: [
      '100% HIPAA compliance',
      '5000+ virtual consultations/month',
      '40% cost reduction in admin',
      '98% patient satisfaction'
    ]
  },
  {
    industry: 'Fintech & Banking',
    iconName: 'Car',
    image: automotiveImg,
    challenge: 'Developing secure digital banking solution with real-time transactions, fraud detection, and seamless user experience.',
    solution: 'Mobile-first banking app with biometric authentication, AI fraud detection, instant transfers, and personal finance management.',
    results: [
      'Zero security breaches',
      '1M+ active users',
      '99.9% uptime reliability',
      'Industry-leading NPS score'
    ]
  },
  {
    industry: 'Education & E-Learning',
    iconName: 'Laptop',
    image: technologyImg,
    challenge: 'Building interactive learning platform with live classes, course management, progress tracking, and certification programs.',
    solution: 'Cloud-based LMS with video streaming, interactive quizzes, student analytics, mobile apps, and integration with payment systems.',
    results: [
      '50,000+ enrolled students',
      '85% course completion rate',
      '4.8/5 average course rating',
      'Multi-language support'
    ]
  },
  {
    industry: 'Logistics & Delivery',
    iconName: 'Package',
    image: consumerGoodsImg,
    challenge: 'Creating real-time delivery tracking system with route optimization, driver management, and customer notifications.',
    solution: 'Full-stack logistics platform with GPS tracking, AI route optimization, driver mobile app, and customer portal with live tracking.',
    results: [
      '35% reduction in delivery time',
      '25% fuel cost savings',
      '99% on-time delivery rate',
      'Real-time order tracking'
    ]
  },
  {
    industry: 'Restaurant & Food Delivery',
    iconName: 'UtensilsCrossed',
    image: foodBeverageImg,
    challenge: 'Developing multi-vendor food delivery platform with order management, real-time tracking, and commission processing.',
    solution: 'Complete food delivery ecosystem with customer app, restaurant dashboard, delivery partner app, and admin panel.',
    results: [
      '100+ restaurant partners',
      '20,000+ monthly orders',
      '30-min average delivery time',
      '4.6★ average rating'
    ]
  }
];

const testimonials:any[] = [
  {
    quote: "The e-commerce platform they built transformed our business. Sales increased by 300% and our customers love the seamless mobile experience. The AI-powered recommendations boosted our average order value significantly.",
    name: "Sarah Mitchell",
    role: "CEO, TechRetail Solutions",
    image: testimonial1Img,
    ringColor: "ring-blue-200"
  },
  {
    quote: "Their HIPAA-compliant telemedicine platform exceeded our expectations. We now handle 5000+ virtual consultations monthly with complete security and patient satisfaction scores above 98%.",
    name: "Dr. James Chen",
    role: "Medical Director, HealthFirst",
    image: testimonial2Img,
    ringColor: "ring-teal-200"
  },
  {
    quote: "The custom fintech solution they developed is rock solid. With 1M+ active users and 99.9% uptime, we've had zero security incidents. Their expertise in mobile-first development is outstanding.",
    name: "Robert Johnson",
    role: "CTO, FinanceHub",
    image: testimonial3Img,
    ringColor: "ring-blue-200"
  }
];
---

<BaseLayout title="Use Cases - Industry Solutions">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image 
        src={heroBgImg}
        alt="Industry solutions and use cases"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-linear-to-r from-blue-600 to-teal-600 text-white text-sm font-semibold rounded-full shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
          </svg>
          Industry Solutions
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Industry <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 via-teal-400 to-blue-400">
            Use Cases
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
          Real-world software solutions delivering measurable results across diverse industries. 
          See how we've transformed businesses with technology.
        </p>
      </div>
    </div>
  </section>

  <!-- Use Cases with Tabs -->
  <Section background="gray">
    <UseCaseTabs useCases={useCases} client:load />
  </Section>

  <!-- Success Metrics -->
  <Section background="white">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Proven <span class="gradient-text">Results</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Our track record speaks for itself with measurable improvements across key performance indicators.
      </p>
    </div>

    <StatsCards 
      stats={[
        { value: '200+', label: 'Projects Delivered', iconName: 'CheckCircle2' },
        { value: '50+', label: 'Happy Clients', iconName: 'TrendingDown' },
        { value: '99%', label: 'Client Satisfaction', iconName: 'Users' },
        { value: '5+', label: 'Years Experience', iconName: 'Package' }
      ]}
      client:load 
    />
  </Section>

  <!-- Testimonials Section -->
  <Section background="gray">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Client Success Stories
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Trusted by <span class="gradient-text">Industry Leaders</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        See how we've helped companies across different industries transform their operations and achieve remarkable results.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <TestimonialCard testimonial={testimonial} />
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-32 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={ctaBgImg}
        alt="Let's work together"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-blue-900/95 to-teal-900/95"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-block px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          Get Started Today
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Ready to Build Your <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">Custom Solution</span>?
        </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-12 max-w-2xl mx-auto leading-relaxed">
          Every business has unique requirements. Let us create a customized software solution for your success.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href="/rfq" size="lg" class="bg-blue-600! hover:bg-blue-700! text-white! shadow-2xl!">
            Get Started
          </Button>
          <Button href="/capabilities" size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
            View Products
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

