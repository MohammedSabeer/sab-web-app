---
import BaseLayout from '@layouts/BaseLayout.astro';
import ConsultationCheckout from '@components/react/ConsultationCheckout';
---

<BaseLayout
  title="Book a Consultation – SABI TECH | ₹2,000/hour"
  description="Book a one-on-one expert consultation with the SABI TECH team. Choose 1, 2 or 4 hours at ₹2,000/hr. Covers software strategy, architecture, development planning and more."
>
  <!-- Hero -->
  <section class="relative bg-linear-to-br from-slate-900 via-blue-950 to-slate-900 py-20 overflow-hidden">
    <!-- Decorative blobs -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3 pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <div class="inline-flex items-center gap-2 bg-blue-500/20 border border-blue-400/30 rounded-full px-4 py-1.5 text-blue-300 text-sm font-medium mb-6">
        <span class="w-2 h-2 bg-blue-400 rounded-full animate-pulse"></span>
        Expert Consultation · Video Call
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-4">
        Book a Consultation<br />
        <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">with Our Experts</span>
      </h1>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto mb-6 leading-relaxed">
        Get focused, actionable advice from our software specialists. Whether you're starting a new product, scaling an existing platform, or solving a technical challenge — we're here to help.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-slate-400">
        <div class="flex items-center gap-2">
          <span class="text-green-400">✓</span>
          No hidden charges
        </div>
        <div class="flex items-center gap-2">
          <span class="text-green-400">✓</span>
          Free reschedule (48 hrs notice)
        </div>
        <div class="flex items-center gap-2">
          <span class="text-green-400">✓</span>
          Secure payment via Paytm
        </div>
        <div class="flex items-center gap-2">
          <span class="text-green-400">✓</span>
          Confirmation within 2 hrs
        </div>
      </div>
    </div>
  </section>

  <!-- Checkout Widget -->
  <section class="bg-slate-50 min-h-screen py-12">
    <ConsultationCheckout client:load />
  </section>

  <!-- Why consult with us -->
  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-center text-slate-900 mb-10">What to Expect from Your Session</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: '🎯',
            title: 'Focused Agenda',
            desc: 'Our consultant prepares a custom agenda based on your submitted requirements before the call.',
          },
          {
            icon: '💡',
            title: 'Actionable Insights',
            desc: "You'll leave with clear next steps, technology choices, and a realistic roadmap.",
          },
          {
            icon: '📝',
            title: 'Session Summary',
            desc: 'We email a written summary with key decisions and recommendations after every session.',
          },
          {
            icon: '🔄',
            title: 'Follow-up Support',
            desc: 'Up to 3 follow-up questions via email for 7 days after your consultation at no extra charge.',
          },
        ].map((item) => (
          <div class="bg-slate-50 rounded-2xl p-6 text-center border border-slate-100">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-semibold text-slate-800 mb-2">{item.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-center text-slate-900 mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          {
            q: 'How will the consultation happen?',
            a: 'All consultations are conducted via video call on Google Meet or Zoom. You\'ll receive a meeting link by email and WhatsApp 30 minutes before your session.',
          },
          {
            q: 'Can I reschedule my session?',
            a: 'Yes — you can reschedule once at no extra charge, provided you give at least 48 hours\' notice before the session start time.',
          },
          {
            q: 'Is a refund available if I cancel?',
            a: 'Yes, if you cancel more than 48 hours before your session you\'ll receive a full refund. Cancellations within 48 hours are non-refundable. See our Refund Policy for full details.',
          },
          {
            q: 'What topics can I get help with?',
            a: 'Software architecture, web & mobile development, cloud infrastructure, database design, API design, product strategy, team upskilling, code reviews, and technology selection.',
          },
          {
            q: 'Will GST be charged?',
            a: 'Yes, GST @ 18% applies to all consultation fees as per Indian tax regulations. The total payable (inclusive of GST) is displayed clearly before you pay.',
          },
        ].map((item, i) => (
          <details class="bg-white border border-slate-200 rounded-xl p-5 group">
            <summary class="font-semibold text-slate-800 cursor-pointer list-none flex justify-between items-center">
              {item.q}
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-sm text-slate-500 leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
