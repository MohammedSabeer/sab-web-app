---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import CapabilityAccordion from '../components/react/CapabilityAccordion';
import { Image } from 'astro:assets';
import ImageReveal from '../components/react/ImageReveal';

import warehouseImg from '@assets/photo-1566576721346-d4a3b4eaeb55.jpg';
import manufacturingImg from '@assets/photo-1581091226825-a6a2a5aee158.jpg';
import transportationImg from '@assets/photo-1601584115197-04ecc0da31d7.jpg';
import supplyChainImg from '@assets/photo-1460925895917-afdab827c52f.jpg';
import valueAddedServicesImg from '@assets/photo-1558618666-fcd25c85cd64.jpg';
import technologyIntegrationImg from '@assets/photo-1558494949-ef010cbdcc31.jpg';
import heroBgImg from '@assets/photo-1586528116311-ad8dd3c8310d.jpg';
import ctaBgImg from '@assets/photo-1553413077-190dd305871c.jpg';

const capabilities = [
  {
    title: 'AI Solutions',
    description: 'Harness the power of artificial intelligence with machine learning models, natural language processing, and intelligent automation solutions.',
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
    </svg>`,
    image: warehouseImg,
    features: [
      'Machine learning models',
      'Predictive analytics',
      'Natural language processing',
      'Computer vision',
      'Intelligent automation'
    ]
  },
  {
    title: 'E-Commerce Mobile App',
    description: 'Full-featured e-commerce mobile applications with seamless payment integration, real-time inventory, and exceptional user experiences.',
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
    </svg>`,
    image: manufacturingImg,
    features: [
      'Product catalog & search',
      'Secure payment gateway',
      'Order tracking',
      'Push notifications',
      'Customer reviews & ratings'
    ]
  },
  {
    title: 'Android Apps',
    description: 'Native Android applications built with Kotlin and Java, optimized for performance and following Material Design guidelines.',
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
    </svg>`,
    image: transportationImg,
    features: [
      'Kotlin & Java development',
      'Material Design UI',
      'Play Store optimization',
      'Offline functionality',
      'Firebase integration'
    ]
  },
  {
    title: 'iOS Apps',
    description: 'Beautiful, high-performance iOS applications using Swift and SwiftUI, designed specifically for the Apple ecosystem.',
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
    </svg>`,
    image: supplyChainImg,
    features: [
      'Swift & SwiftUI',
      'App Store guidelines',
      'Apple Pay integration',
      'iCloud synchronization',
      'ARKit capabilities'
    ]
  },
  {
    title: 'Multi Vendor Application',
    description: 'Comprehensive marketplace platforms enabling multiple vendors to sell products and manage their businesses efficiently.',
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
    </svg>`,
    image: valueAddedServicesImg,
    features: [
      'Vendor dashboards',
      'Commission management',
      'Multi-store support',
      'Analytics & reporting',
      'Product approval workflows'
    ]
  },
  {
    title: 'High Resolution Website & Web Apps',
    description: 'Stunning, responsive web applications and websites built with modern frameworks for exceptional performance and user experience.',
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>`,
    image: technologyIntegrationImg,
    features: [
      'React, Vue, Angular frameworks',
      'Progressive Web Apps (PWA)',
      'RESTful & GraphQL APIs',
      'Cloud deployment',
      'SEO optimization'
    ]
  }
];
---

<BaseLayout title="Our Products - TechSolutions">
  <!-- Hero Section -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <Image 
        src={heroBgImg}
        alt="Modern logistics and manufacturing capabilities"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-slate-900/95 via-slate-900/80 to-slate-900/50"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center px-4 py-2 mb-6 bg-linear-to-r from-blue-600 to-teal-600 text-white text-sm font-semibold rounded-full shadow-lg">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          Our Software Products
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Our <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 via-teal-400 to-blue-400">
            Products
          </span>
      </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed">
        Cutting-edge software solutions designed to transform your business operations 
        and accelerate your digital growth.
      </p>
      </div>
    </div>
  </section>

  <!-- Main Capabilities -->
  <Section background="gray">
    <!-- Accordion View for Mobile/Compact -->
    <div class="lg:hidden mb-12">
      <CapabilityAccordion capabilities={capabilities} client:load />
    </div>
    
    <!-- Grid View for Desktop -->
    <div class="hidden lg:block space-y-24">
      {capabilities.map((capability, index) => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'lg:grid-flow-dense' : ''}`}>
          <div class={`${index % 2 === 1 ? 'lg:col-start-2' : ''} animate-fadeInUp`}>
            <div class="flex items-center justify-center w-16 h-16 rounded-xl bg-linear-to-br from-blue-500 to-teal-500 text-white mb-6 shadow-lg">
              <div class="w-8 h-8" set:html={capability.icon.replace('w-12 h-12', 'w-8 h-8').replace('currentColor', 'white')} />
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
              {capability.title}
            </h2>
            <p class="text-lg text-gray-600 mb-6 leading-relaxed">
              {capability.description}
            </p>
            <ul class="space-y-3">
              {capability.features.map((feature) => (
                <li class="flex items-center space-x-3">
                  <svg class="w-5 h-5 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-gray-700">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class={`${index % 2 === 1 ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
            <ImageReveal client:load delay={index * 0.1}>
              <div class="relative aspect-4/3 group overflow-hidden rounded-2xl shadow-2xl">
                <Image 
                  src={capability.image}
                  alt={capability.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width={1200}
                  height={800}
                />
                <div class="absolute inset-0 bg-linear-to-t from-slate-900/60 via-transparent to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
                  <h3 class="text-2xl font-bold mb-2">{capability.title}</h3>
                  <p class="text-gray-200">{capability.description}</p>
                </div>
              </div>
            </ImageReveal>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Process Section -->
  <Section background="white">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Our Approach
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Our <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Process</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        A streamlined approach to deliver exceptional results every time.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { 
          step: '01', 
          title: 'Discovery', 
          description: 'Understand your business goals and technical requirements',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>`
        },
        { 
          step: '02', 
          title: 'Design', 
          description: 'Create intuitive UI/UX and technical architecture',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>`
        },
        { 
          step: '03', 
          title: 'Development', 
          description: 'Build robust, scalable applications using modern tech',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>`
        },
        { 
          step: '04', 
          title: 'Launch & Support', 
          description: 'Deploy to production and provide ongoing maintenance',
          icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>`
        }
      ].map((process, index) => (
        <Card hover class="text-center animate-fadeInUp group" style={`animation-delay: ${index * 0.1}s`}>
          <div class="flex items-center justify-center w-16 h-16 mx-auto mb-4 rounded-xl bg-linear-to-br from-blue-500 to-teal-500 text-white shadow-lg group-hover:scale-110 transition-transform">
            <div set:html={process.icon} />
          </div>
          <div class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600 mb-2">{process.step}</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{process.title}</h3>
          <p class="text-gray-600 leading-relaxed">{process.description}</p>
        </Card>
      ))}
    </div>
  </Section>

  <!-- CTA Section -->
  <section class="relative py-32 overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <Image 
        src={ctaBgImg}
        alt="Modern warehouse operations"
        class="w-full h-full object-cover"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-blue-900/95 to-teal-900/95"></div>
    </div>

    <!-- Content -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center text-white">
        <div class="inline-block px-4 py-2 mb-6 bg-white/10 backdrop-blur-sm text-white text-sm font-semibold rounded-full">
          Get Started Today
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Ready to Build Your <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">Custom Solution</span>?
      </h2>
        <p class="text-xl md:text-2xl text-slate-200 mb-12 max-w-2xl mx-auto leading-relaxed">
          Let's discuss how our software products can transform your business and drive digital innovation.
      </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <Button href="/rfq" size="lg" class="bg-blue-600! hover:bg-blue-700! text-white! shadow-2xl!">
          Get Started
        </Button>
          <Button href="/facilities" size="lg" variant="outline" class="border-2! border-white! text-white! hover:bg-white/10! shadow-2xl!">
          View Portfolio
        </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

