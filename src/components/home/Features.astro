---
import Card from '../ui/Card.astro';
import Section from '../ui/Section.astro';

const features = [
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 1 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
    </svg>`,
    title: 'AI & Machine Learning',
    description: 'Intelligent solutions powered by advanced AI algorithms, machine learning models, and predictive analytics for smarter decision-making.'
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
    </svg>`,
    title: 'Mobile Development',
    description: 'Native iOS and Android applications with seamless user experiences, optimized performance, and cross-platform compatibility.'
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
    </svg>`,
    title: 'Cloud Infrastructure',
    description: 'Scalable cloud solutions with AWS, Azure, and Google Cloud integration, ensuring reliability, security, and high availability.'
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
    </svg>`,
    title: 'Real-Time Analytics',
    description: 'Comprehensive dashboards and reporting systems providing complete visibility into your business metrics and user behavior.'
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
    </svg>`,
    title: 'Custom Development',
    description: 'Tailored software solutions designed to meet your unique business requirements, from MVPs to enterprise-scale applications.'
  },
  {
    icon: `<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
    </svg>`,
    title: 'Expert Support',
    description: 'Dedicated development teams and 24/7 technical support to ensure smooth deployment, maintenance, and continuous improvement.'
  }
];
---

<Section background="gray">
  <div class="text-center mb-16 animate-fadeInUp">
    <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
      Our Core <span class="gradient-text">Capabilities</span>
    </h2>
    <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      Comprehensive software development solutions designed to transform your business and accelerate digital growth.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {features.map((feature, index) => (
      <Card hover class="animate-fadeInUp" style={`animation-delay: ${index * 0.1}s`}>
        <div class="text-primary-600 mb-4" set:html={feature.icon} />
        <h3 class="text-xl font-bold text-gray-900 mb-3">{feature.title}</h3>
        <p class="text-gray-600 leading-relaxed">{feature.description}</p>
      </Card>
    ))}
  </div>
</Section>

