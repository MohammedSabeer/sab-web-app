---
interface Industry {
  title: string;
  description: string;
  iconGradient: string;
  iconPath: string;
  features: string[];
}

const industries: Industry[] = [
  {
    title: "E-Commerce & Retail",
    description: "Custom online stores, inventory management systems, and seamless shopping experiences that drive sales and customer satisfaction.",
    iconGradient: "from-blue-600 to-teal-600",
    iconPath: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z",
    features: ["Shopping cart systems", "Payment gateway integration", "Order management"]
  },
  {
    title: "Healthcare & Wellness",
    description: "HIPAA-compliant health applications, telemedicine platforms, and patient management systems for modern healthcare.",
    iconGradient: "from-blue-500 to-blue-600",
    iconPath: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
    features: ["Appointment scheduling", "Patient portals", "Health tracking"]
  },
  {
    title: "Finance & Fintech",
    description: "Secure banking apps, cryptocurrency platforms, and financial management tools with enterprise-grade security.",
    iconGradient: "from-teal-500 to-teal-600",
    iconPath: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    features: ["Secure transactions", "Real-time analytics", "Compliance management"]
  },
  {
    title: "Education & E-Learning",
    description: "Interactive learning platforms, course management systems, and educational apps that enhance knowledge delivery.",
    iconGradient: "from-purple-500 to-purple-600",
    iconPath: "M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
    features: ["Course management", "Video streaming", "Progress tracking"]
  },
  {
    title: "Hospitality & Travel",
    description: "Booking systems, property management solutions, and guest experience apps for the hospitality industry.",
    iconGradient: "from-orange-500 to-orange-600",
    iconPath: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    features: ["Reservation systems", "Customer management", "Loyalty programs"]
  },
  {
    title: "Logistics & Delivery",
    description: "Fleet management, real-time tracking, and delivery optimization platforms for logistics companies.",
    iconGradient: "from-slate-700 to-slate-800",
    iconPath: "M13 10V3L4 14h7v7l9-11h-7z",
    features: ["Route optimization", "Real-time tracking", "Fleet management"]
  }
];

const checkmarkPath = "M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z";
---

<section class="py-24 bg-linear-to-b from-slate-50 to-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Industries We Serve
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Solutions for <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Every Industry</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Custom software solutions designed to meet the unique challenges and opportunities of your industry.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {industries.map((industry) => (
        <div class="group bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all hover:-translate-y-2 border border-slate-100">
          <div class={`w-16 h-16 rounded-xl bg-linear-to-br ${industry.iconGradient} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform`}>
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={industry.iconPath} />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-3">{industry.title}</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            {industry.description}
          </p>
          <ul class="space-y-2 text-sm text-slate-600">
            {industry.features.map((feature) => (
              <li class="flex items-center">
                <svg class="w-4 h-4 text-teal-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d={checkmarkPath} clip-rule="evenodd" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <a 
        href="/use-cases" 
        class="inline-flex items-center px-8 py-4 text-base font-semibold text-white bg-linear-to-r from-blue-600 to-teal-600 hover:from-blue-700 hover:to-teal-700 rounded-lg shadow-lg hover:shadow-xl transition-all group"
      >
        View Industry Solutions
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
