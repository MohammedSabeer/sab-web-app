---
import ImageReveal from '@components/react/ImageReveal';
import { Image } from 'astro:assets';
import aiNetworkImg from '@assets/ai-neural-network.svg';
import mobileAppImg from '@assets/mobile-app-dev.svg';
import webDevImg from '@assets/web-development.svg';
import analyticsDashboardImg from '@assets/analytics-dashboard.svg';
import ecommercePlatformImg from '@assets/ecommerce-platform.svg';
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 bg-teal-100 text-teal-800 text-sm font-semibold rounded-full">
        Our Portfolio
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        World-Class <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-teal-600">Projects</span>
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Innovative software solutions and cutting-edge applications designed for 
        excellence across multiple industries and platforms.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Large featured image -->
      <div class="md:row-span-2">
        <ImageReveal client:load delay={0}>
          <div class="relative h-full group overflow-hidden rounded-2xl shadow-xl">
            <Image 
              src={aiNetworkImg}
              alt="AI and Machine Learning Solutions"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width={1200}
              height={800}
            />
            <div class="absolute inset-0 bg-linear-to-t from-slate-900/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
              <h3 class="text-2xl font-bold mb-2">AI-Powered Solutions</h3>
              <p class="text-gray-200">Machine learning and intelligent automation systems</p>
            </div>
          </div>
        </ImageReveal>
      </div>

      <ImageReveal client:load delay={0.1}>
        <div class="relative h-64 lg:h-auto group overflow-hidden rounded-2xl shadow-xl">
          <Image 
            src={mobileAppImg}
            alt="Mobile application development"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            width={800}
            height={600}
          />
          <div class="absolute inset-0 bg-linear-to-t from-slate-900/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <h3 class="text-xl font-bold mb-1">Mobile Applications</h3>
            <p class="text-sm text-gray-200">Native iOS & Android development</p>
          </div>
        </div>
      </ImageReveal>

      <ImageReveal client:load delay={0.2}>
        <div class="relative h-64 lg:h-auto group overflow-hidden rounded-2xl shadow-xl">
          <Image 
            src={webDevImg}
            alt="Web application development"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            width={800}
            height={600}
          />
          <div class="absolute inset-0 bg-linear-to-t from-slate-900/80 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <h3 class="text-xl font-bold mb-1">Web Development</h3>
            <p class="text-sm text-gray-200">Modern, responsive applications</p>
          </div>
        </div>
      </ImageReveal>

      <div class="lg:row-start-3">        
        <ImageReveal client:load delay={0.3}>
          <div class="lg:col-span-2 relative h-64 lg:h-auto group overflow-hidden rounded-2xl shadow-xl">
            <Image 
              src={analyticsDashboardImg}
              alt="Analytics and data visualization dashboard"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width={1200}
              height={600}
            />
            <div class="absolute inset-0 bg-linear-to-t from-slate-900/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
              <h3 class="text-xl font-bold mb-1">Analytics Dashboard</h3>
              <p class="text-sm text-gray-200">Real-time data visualization and insights</p>
            </div>
          </div>
        </ImageReveal>
      </div>
      <div class="lg:row-start-2 lg:col-start-2 lg:row-span-2 lg:col-span-2">        
        <ImageReveal client:load delay={0.4}>
          <div class="relative h-64 lg:h-auto group overflow-hidden rounded-2xl shadow-xl">
            <Image 
              src={ecommercePlatformImg}
              alt="E-commerce platform development"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width={800}
              height={600}
            />
            <div class="absolute inset-0 bg-linear-to-t from-slate-900/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
              <h3 class="text-xl font-bold mb-1">E-Commerce Platform</h3>
              <p class="text-sm text-gray-200">Scalable multi-vendor marketplace</p>
            </div>
          </div>
        </ImageReveal>
      </div>
    </div>
    
    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <a 
        href="/facilities" 
        class="inline-flex items-center px-8 py-4 text-base font-semibold text-white bg-linear-to-r from-teal-600 to-teal-700 hover:from-teal-700 hover:to-teal-800 rounded-lg shadow-lg hover:shadow-xl transition-all group"
      >
        Explore Our Portfolio
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

