---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import heroBgImg from '@assets/hero-tech-background.svg';
---

<section class="relative h-screen min-h-[700px] flex items-center overflow-hidden">
  <!-- Animated Background -->
  <div class="absolute inset-0">
    <Image 
      src={heroBgImg}
      alt="Innovative software development and technology"
      class="w-full h-full object-cover"
      width={2070}
      height={1380}
      decoding="async"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-linear-to-r from-slate-900/40 via-transparent to-slate-900/40"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto text-center">
      <div class="inline-flex items-center px-6 py-3 mb-8 bg-linear-to-r from-blue-600/90 to-teal-600/90 backdrop-blur-sm text-white text-sm font-semibold rounded-full shadow-2xl animate-fadeInUp">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Award-Winning Software Development
      </div>
      
      <h1 class="text-5xl md:text-6xl lg:text-8xl font-extrabold text-white mb-8 leading-tight animate-fadeInUp" style="animation-delay: 0.1s">
        Build The Future
        <span class="block text-transparent bg-clip-text bg-linear-to-r from-blue-400 via-teal-300 to-emerald-400 mt-3">
          With AI & Innovation
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl lg:text-3xl text-slate-200 mb-12 max-w-4xl mx-auto leading-relaxed font-light animate-fadeInUp" style="animation-delay: 0.2s">
        Transform your vision into reality with cutting-edge AI solutions, stunning mobile apps, 
        <span class="text-teal-300 font-normal">and powerful web platforms</span> built by expert developers.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center mb-16 animate-fadeInUp" style="animation-delay: 0.3s">
        <Button href="/rfq" size="lg" class="bg-linear-to-r! from-blue-600! to-teal-600! hover:from-blue-700! hover:to-teal-700! text-white! shadow-2xl! px-10! py-4! text-lg!">
          Start Your Project
          <svg class="w-5 h-5 ml-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </Button>
        <Button href="/capabilities" size="lg" variant="outline" class="border-2! border-white! bg-white/10! backdrop-blur-sm! text-white! hover:bg-white/20! shadow-2xl! px-10! py-4! text-lg!">
          Explore Solutions
        </Button>
      </div>

      <!-- Enhanced Stats Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 pt-12 border-t border-white/20 animate-fadeInUp" style="animation-delay: 0.4s">
        <div class="group cursor-default">
          <div class="text-4xl md:text-5xl font-extrabold mb-2">
            <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-teal-400">200+</span>
          </div>
          <div class="text-base text-slate-300 group-hover:text-white transition-colors">Projects Delivered</div>
        </div>
        <div class="group cursor-default">
          <div class="text-4xl md:text-5xl font-extrabold mb-2">
            <span class="text-transparent bg-clip-text bg-linear-to-r from-teal-400 to-emerald-400">50+</span>
          </div>
          <div class="text-base text-slate-300 group-hover:text-white transition-colors">Happy Clients</div>
        </div>
        <div class="group cursor-default">
          <div class="text-4xl md:text-5xl font-extrabold mb-2">
            <span class="text-transparent bg-clip-text bg-linear-to-r from-purple-400 to-pink-400">99%</span>
          </div>
          <div class="text-base text-slate-300 group-hover:text-white transition-colors">Satisfaction Rate</div>
        </div>
        <div class="group cursor-default">
          <div class="text-4xl md:text-5xl font-extrabold mb-2">
            <span class="text-transparent bg-clip-text bg-linear-to-r from-pink-400 to-orange-400">24/7</span>
          </div>
          <div class="text-base text-slate-300 group-hover:text-white transition-colors">Expert Support</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2">
    <div class="flex flex-col items-center gap-2 text-white/60 hover:text-white/80 transition-colors cursor-pointer animate-bounce">
      <span class="text-xs uppercase tracking-wider">Scroll</span>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

